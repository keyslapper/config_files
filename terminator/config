[global_config]
  focus = mouse
  geometry_hinting = True
  new_tab_after_current_tab = True
[keybindings]
  reset_clear = <Alt>l
  layout_launcher = ""
[profiles]
  [[default]]
    background_darkness = 0.7
    background_type = transparent
    font = Adwaita Mono 14
    show_titlebar = False
    scrollbar_position = hidden
    use_system_font = False
    copy_on_selection = True
[layouts]
  [[default]]
    [[[window0]]]
      type = Window
      parent = ""
    [[[child1]]]
      type = Terminal
      parent = window0
      profile = default
[plugins]
